{
  "name": "fnfuzzy",
  "version": "0.1.0",
  "description": "Lightweight, TypeScript-first fuzzy filter and search. Modern replacement for the fuzzy package.",
  "keywords": [
    "fuzzy",
    "filter",
    "search",
    "match",
    "fuzzy-search",
    "fuzzy-filter",
    "fuzzy-match",
    "autocomplete",
    "typeahead"
  ],
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnrhombus/fnfuzzy"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
